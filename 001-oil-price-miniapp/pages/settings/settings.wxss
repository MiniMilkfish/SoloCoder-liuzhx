.switch-card {
  margin-bottom: 20rpx;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.switch-info {
  display: flex;
  flex-direction: column;
}

.switch-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.switch-desc {
  font-size: 24rpx;
  color: #999;
}

.settings-card {
  margin-bottom: 20rpx;
}

.section-header {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1976d2;
}

.radio-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
}

.radio-content {
  display: flex;
  flex-direction: column;
  margin-left: 16rpx;
  flex: 1;
}

.radio-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.radio-desc {
  font-size: 24rpx;
  color: #999;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.setting-label {
  font-size: 30rpx;
  color: #333;
}

.setting-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.setting-value-row {
  display: flex;
  align-items: center;
}

.setting-value {
  font-size: 28rpx;
  color: #1976d2;
}

.arrow {
  font-size: 28rpx;
  color: #ccc;
  margin-left: 8rpx;
}

.oil-type-list {
  display: flex;
  flex-wrap: wrap;
}

.oil-type-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 8rpx;
  border: 2rpx solid #e0e0e0;
  background-color: #fafafa;
}

.oil-type-item.active {
  border-color: #1976d2;
  background-color: #e3f2fd;
}

.oil-type-name {
  font-size: 28rpx;
  color: #666;
}

.oil-type-item.active .oil-type-name {
  color: #1976d2;
  font-weight: bold;
}

.check-icon {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background-color: #1976d2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon {
  font-size: 20rpx;
  color: #fff;
}

.threshold-section {
  display: flex;
  flex-direction: column;
}

.threshold-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.threshold-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 16rpx;
}

.threshold-input-wrapper {
  width: 120rpx;
  height: 60rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  background-color: #fafafa;
}

.threshold-input {
  width: 100%;
  height: 100%;
  text-align: center;
  font-size: 32rpx;
  color: #1976d2;
  font-weight: bold;
}

.threshold-unit {
  font-size: 26rpx;
  color: #999;
  margin-left: 12rpx;
}

.threshold-desc {
  font-size: 24rpx;
  color: #999;
}

.picker-wrapper {
  display: flex;
  align-items: center;
}

.actions-card {
  margin-bottom: 20rpx;
  padding: 0;
  overflow: hidden;
}

.action-item {
  padding: 32rpx;
  text-align: center;
}

.action-divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 0 32rpx;
}

.action-text {
  font-size: 30rpx;
}

.action-text.test {
  color: #1976d2;
}

.action-text.clear {
  color: #f44336;
}

.tips-card {
  padding: 24rpx;
  background-color: #e3f2fd;
  border-radius: 8rpx;
  margin-bottom: 40rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #1565c0;
  line-height: 1.6;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.picker-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  z-index: 1001;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-cancel,
.picker-confirm {
  font-size: 30rpx;
  color: #1976d2;
}

.picker-cancel {
  color: #999;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker-view {
  height: 400rpx;
  background-color: #fff;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
  line-height: 80rpx;
}

.day-picker-content {
  display: flex;
  flex-wrap: wrap;
  padding: 30rpx 40rpx;
  padding-bottom: 60rpx;
}

.day-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  border: 2rpx solid #e0e0e0;
  background-color: #fafafa;
}

.day-item.active {
  border-color: #1976d2;
  background-color: #1976d2;
}

.day-name {
  font-size: 26rpx;
  color: #666;
}

.day-item.active .day-name {
  color: #fff;
  font-weight: bold;
}
