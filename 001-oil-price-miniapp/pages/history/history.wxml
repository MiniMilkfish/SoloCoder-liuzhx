<view class="container">
  <view class="header-card card">
    <view class="filter-row">
      <view class="filter-item" bindtap="showCityPicker">
        <text class="filter-label">城市</text>
        <text class="filter-value">{{city}}</text>
        <text class="arrow">›</text>
      </view>
      <view class="filter-item" bindtap="showOilTypePicker">
        <text class="filter-label">油号</text>
        <text class="filter-value">{{oilType}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="stats-card card" wx:if="{{historyData && !loading}}">
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-label">最高价</text>
        <text class="stat-value max">{{historyData.maxPrice.toFixed(2)}}</text>
        <text class="stat-unit">元/升</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">最低价</text>
        <text class="stat-value min">{{historyData.minPrice.toFixed(2)}}</text>
        <text class="stat-unit">元/升</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">平均价</text>
        <text class="stat-value avg">{{historyData.avgPrice.toFixed(2)}}</text>
        <text class="stat-unit">元/升</text>
      </view>
    </view>
  </view>

  <view class="chart-card card" wx:if="{{!loading}}">
    <view class="chart-header">
      <text class="chart-title">近30天油价走势</text>
    </view>
    <view class="chart-container">
      <canvas 
        type="2d" 
        id="historyChart" 
        canvas-id="historyChart" 
        style="width: {{chartWidth}}px; height: {{chartHeight}}px;"
        class="chart-canvas">
      </canvas>
    </view>
  </view>

  <view class="prediction-card card" wx:if="{{predictionData && !loading}}">
    <view class="prediction-header">
      <text class="prediction-title">油价预测</text>
      <view class="prediction-tag">
        <text class="tag-text">预测</text>
      </view>
    </view>
    <view class="prediction-content">
      <view class="prediction-item">
        <text class="prediction-label">下次调价时间</text>
        <text class="prediction-value highlight">{{predictionData.nextAdjustmentDate}}</text>
      </view>
      <view class="prediction-item">
        <text class="prediction-label">距离调价</text>
        <text class="prediction-value">{{predictionData.nextAdjustmentDays}}天</text>
      </view>
      <view class="prediction-tips">
        <text class="tips-text">💡 预测数据仅供参考，实际以官方公布为准</text>
      </view>
    </view>
  </view>

  <view class="legend-card card" wx:if="{{!loading}}">
    <view class="legend-title">图例说明</view>
    <view class="legend-list">
      <view class="legend-item">
        <view class="legend-line history"></view>
        <text class="legend-text">历史价格</text>
      </view>
      <view class="legend-item">
        <view class="legend-line prediction"></view>
        <text class="legend-text">预测价格（虚线）</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot max"></view>
        <text class="legend-text">最高价</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot min"></view>
        <text class="legend-text">最低价</text>
      </view>
      <view class="legend-item">
        <view class="legend-line avg"></view>
        <text class="legend-text">平均价格</text>
      </view>
    </view>
  </view>

  <view class="loading-card card" wx:if="{{loading}}">
    <view class="loading-container">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在加载数据...</text>
    </view>
  </view>

  <view class="picker-mask" wx:if="{{showCityPicker}}" bindtap="hideCityPicker"></view>
  <view class="picker-container" wx:if="{{showCityPicker}}">
    <view class="picker-header">
      <text class="picker-cancel" bindtap="hideCityPicker">取消</text>
      <text class="picker-title">选择城市</text>
      <text class="picker-confirm" bindtap="hideCityPicker">确定</text>
    </view>
    <picker-view class="picker-view" value="{{[cityPickerIndex]}}" bindchange="onCityPickerChange">
      <picker-view-column>
        <view wx:for="{{cityPickerColumns}}" wx:key="index" class="picker-item">{{item}}</view>
      </picker-view-column>
    </picker-view>
  </view>

  <view class="picker-mask" wx:if="{{showOilTypePicker}}" bindtap="hideOilTypePicker"></view>
  <view class="picker-container" wx:if="{{showOilTypePicker}}">
    <view class="picker-header">
      <text class="picker-cancel" bindtap="hideOilTypePicker">取消</text>
      <text class="picker-title">选择油号</text>
      <text class="picker-confirm" bindtap="hideOilTypePicker">确定</text>
    </view>
    <picker-view class="picker-view" value="{{[oilTypePickerIndex]}}" bindchange="onOilTypePickerChange">
      <picker-view-column>
        <view wx:for="{{oilTypePickerColumns}}" wx:key="index" class="picker-item">{{item}}</view>
      </picker-view-column>
    </picker-view>
  </view>
</view>
