.header-card {
  margin-bottom: 20rpx;
}

.filter-row {
  display: flex;
  justify-content: space-between;
}

.filter-item {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.filter-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
}

.filter-value {
  font-size: 30rpx;
  color: #1976d2;
  font-weight: bold;
}

.arrow {
  font-size: 28rpx;
  color: #ccc;
  margin-left: 8rpx;
}

.stats-card {
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  line-height: 1;
}

.stat-value.max {
  color: #f44336;
}

.stat-value.min {
  color: #4caf50;
}

.stat-value.avg {
  color: #9c27b0;
}

.stat-unit {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.chart-card {
  margin-bottom: 20rpx;
}

.chart-header {
  margin-bottom: 20rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.chart-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 10rpx 0;
}

.chart-canvas {
  background-color: #fff;
}

.prediction-card {
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%);
}

.prediction-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.prediction-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.prediction-tag {
  background-color: #ff9800;
  border-radius: 4rpx;
  padding: 4rpx 12rpx;
  margin-left: 16rpx;
}

.tag-text {
  font-size: 22rpx;
  color: #fff;
}

.prediction-content {
  display: flex;
  flex-direction: column;
}

.prediction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 152, 0, 0.2);
}

.prediction-item:last-child {
  border-bottom: none;
}

.prediction-label {
  font-size: 28rpx;
  color: #666;
}

.prediction-value {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.prediction-value.highlight {
  color: #ff9800;
}

.prediction-tips {
  margin-top: 20rpx;
  padding: 16rpx;
  background-color: rgba(255, 152, 0, 0.1);
  border-radius: 8rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #8d6e63;
}

.legend-card {
  margin-bottom: 20rpx;
}

.legend-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.legend-list {
  display: flex;
  flex-wrap: wrap;
}

.legend-item {
  display: flex;
  align-items: center;
  margin-right: 30rpx;
  margin-bottom: 16rpx;
}

.legend-line {
  width: 40rpx;
  height: 6rpx;
  margin-right: 12rpx;
}

.legend-line.history {
  background-color: #1976d2;
}

.legend-line.prediction {
  border: 2rpx dashed #ff9800;
  background: none;
}

.legend-line.avg {
  border: 2rpx dashed #9c27b0;
  background: none;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.legend-dot.max {
  background-color: #f44336;
}

.legend-dot.min {
  background-color: #4caf50;
}

.legend-text {
  font-size: 24rpx;
  color: #666;
}

.loading-card {
  padding: 80rpx 0;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1976d2;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.picker-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  z-index: 1001;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-cancel,
.picker-confirm {
  font-size: 30rpx;
  color: #1976d2;
}

.picker-cancel {
  color: #999;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker-view {
  height: 400rpx;
  background-color: #fff;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
  line-height: 80rpx;
}
