<view class="container">
  <view class="api-usage-card card" wx:if="{{apiUsageInfo}}">
    <view class="api-usage-header">
      <view class="api-usage-info">
        <text class="api-provider">数据来源: {{apiUsageInfo.providerName}}</text>
        <text class="api-status" wx:if="{{!apiUsageInfo.isMock}}">今日剩余: {{apiUsageInfo.remaining}}/{{apiUsageInfo.total}}次</text>
        <text class="api-status mock" wx:else>模拟数据模式</text>
      </view>
      <view class="api-warning" wx:if="{{apiUsageInfo.isNearLimit && !apiUsageInfo.isMock}}">
        <text class="warning-icon">⚠️</text>
        <text class="warning-text">额度即将用尽</text>
      </view>
    </view>
    <view class="progress-bar" wx:if="{{!apiUsageInfo.isMock}}">
      <view class="progress-fill {{apiUsageInfo.isNearLimit ? 'warning' : ''}}" style="width: {{apiUsageInfo.percentage}}%"></view>
    </view>
  </view>

  <view class="header-card card">
    <view class="location-section" bindtap="showCityPicker">
      <view class="location-icon">
        <text class="iconfont">📍</text>
      </view>
      <view class="location-text">
        <text class="city-name">{{city}}</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="oil-type-section" bindtap="showOilTypePicker">
      <view class="oil-type-text">
        <text class="label">汽油类型</text>
        <text class="oil-type-name">{{oilType}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="price-card card" wx:if="{{!loading && price}}">
    <view class="price-header">
      <text class="price-label">当前油价</text>
      <text class="update-time">更新于 {{updateTime}}</text>
    </view>
    
    <view class="price-main">
      <view class="price-value">
        <text class="currency">¥</text>
        <text class="amount">{{price}}</text>
        <text class="unit">元/升</text>
      </view>
      
      <view class="price-trend {{trend}}">
        <text class="trend-icon">{{trend === 'up' ? '↑' : '↓'}}</text>
        <text class="trend-value">{{Math.abs(change)}}</text>
        <text class="trend-unit">元</text>
      </view>
    </view>

    <view class="price-footer" bindtap="onNavigateToHistory">
      <text class="footer-text">查看历史油价走势</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="loading-card card" wx:if="{{loading}}">
    <view class="loading-container">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在获取油价数据...</text>
    </view>
  </view>

  <view class="tips-card card" wx:if="{{!loading}}">
    <view class="tips-header">
      <text class="tips-icon">💡</text>
      <text class="tips-title">温馨提示</text>
    </view>
    <view class="tips-content">
      <text class="tips-text">• 油价数据仅供参考，实际以加油站为准</text>
      <text class="tips-text">• 国内成品油价格每10个工作日调整一次</text>
      <text class="tips-text">• 点击上方城市或油号可切换查看</text>
    </view>
  </view>

  <view class="picker-mask" wx:if="{{showCityPicker}}" bindtap="hideCityPicker"></view>
  <view class="picker-container" wx:if="{{showCityPicker}}">
    <view class="picker-header">
      <text class="picker-cancel" bindtap="hideCityPicker">取消</text>
      <text class="picker-title">选择城市</text>
      <text class="picker-confirm" bindtap="hideCityPicker">确定</text>
    </view>
    <picker-view class="picker-view" value="{{[cityPickerIndex]}}" bindchange="onCityPickerChange">
      <picker-view-column>
        <view wx:for="{{cityPickerColumns}}" wx:key="index" class="picker-item">{{item}}</view>
      </picker-view-column>
    </picker-view>
  </view>

  <view class="picker-mask" wx:if="{{showOilTypePicker}}" bindtap="hideOilTypePicker"></view>
  <view class="picker-container" wx:if="{{showOilTypePicker}}">
    <view class="picker-header">
      <text class="picker-cancel" bindtap="hideOilTypePicker">取消</text>
      <text class="picker-title">选择油号</text>
      <text class="picker-confirm" bindtap="hideOilTypePicker">确定</text>
    </view>
    <picker-view class="picker-view" value="{{[oilTypePickerIndex]}}" bindchange="onOilTypePickerChange">
      <picker-view-column>
        <view wx:for="{{oilTypePickerColumns}}" wx:key="index" class="picker-item">{{item}}</view>
      </picker-view-column>
    </picker-view>
  </view>
</view>
